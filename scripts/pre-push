#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "${local_sha:-}" ]] && continue

  if [[ "$local_sha" =~ ^0+$ ]]; then
    continue
  fi

  if [[ "$remote_sha" =~ ^0+$ ]]; then
    base="$(git -C "$REPO_ROOT" merge-base "$local_sha" origin/main 2>/dev/null || git -C "$REPO_ROOT" rev-list --max-parents=0 "$local_sha" | tail -1)"
  else
    base="$remote_sha"
  fi

  git -C "$REPO_ROOT" diff --name-only "$base" "$local_sha" >> "$tmp"
done

make -C "$REPO_ROOT" guard

if [[ -s "$tmp" ]]; then
  changed_files=()
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    changed_files+=("$file")
  done < <(sort -u "$tmp")
  "$REPO_ROOT/scripts/verify-verifier.sh" "${changed_files[@]}"
else
  echo "Pre-push verifier gate: no changed files detected."
fi
