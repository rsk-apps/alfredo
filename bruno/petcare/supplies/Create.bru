meta {
name: Create Supply
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/pets/:id/supplies
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{apiKey}}
}

params:path {
  id: {{petId}}
}

body:json {
  {
    "name": "Royal Canin Medium Adult",
    "last_purchased_at": "2026-04-16",
    "estimated_days_supply": 30,
    "notes": "Comprar no Petlove"
  }
}
