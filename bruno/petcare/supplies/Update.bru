meta {
name: Update Supply
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/api/v1/pets/:id/supplies/:sid
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{apiKey}}
}

params:path {
  id: {{petId}}
  sid: {{supplyId}}
}

body:json {
  {
    "last_purchased_at": "2026-05-16",
    "estimated_days_supply": 30,
    "notes": "Novo pacote aberto"
  }
}
